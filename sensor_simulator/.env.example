# ==========================================
# Spirit of Ankh — Environment Variables
# ==========================================
# Copy this file, rename it to .env
# and fill in your real values

# OpenWeatherMap API (free at openweathermap.org/api)
OPENWEATHER_API_KEY=paste_your_key_here

# Snowflake Credentials
SF_USER=your_snowflake_username
SF_PASSWORD=your_snowflake_password
SF_ACCOUNT=abc12345.eu-central-1

# Snowflake Settings (defaults already set in config.py)
SF_WAREHOUSE=TOURISM_WH
SF_DATABASE=TOURISM_DB
SF_SCHEMA=BRONZE
SF_TABLE=RAW_SENSOR_DATA
